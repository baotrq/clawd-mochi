// Copy this file to secrets.h (same folder) and fill in your real network.
// secrets.h is gitignored — only this .example file is committed, so your
// WiFi password never ends up in git history. Leave both blank in secrets.h
// to skip WiFi/NTP entirely; the clock then behaves exactly as if this
// feature didn't exist (millis()-based, set manually over Serial).

#pragma once

#define STA_SSID ""   // your 2.4 GHz WiFi network name
#define STA_PASS ""   // your WiFi password

// --- Standalone Sync & WiFi Remote Control ---
#define CLAUDE_ACCESS_TOKEN "" // Your Anthropic OAuth Access Token (from ~/.claude/.credentials.json)
#define MQTT_BROKER "broker.hivemq.com" // Public MQTT broker (or public.cloud.shiftr.io)
#define MQTT_TOPIC_SUB "baotrq/clawd/control/replace_with_unique_id" // Unique topic for commands
#define MQTT_TOPIC_PUB "baotrq/clawd/status/replace_with_unique_id"  // Unique topic for status updates
